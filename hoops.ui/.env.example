# Copy this file to .env and fill in real values.
# .env is git-ignored and must never be committed.

# Admin credentials used by auth.setup.ts to log in once and save session state.
E2E_USERNAME=your-admin-email@example.com
E2E_PASSWORD=your-admin-password

# Optional: override the base URL (defaults to http://localhost:4200)
# E2E_BASE_URL=http://localhost:4200
