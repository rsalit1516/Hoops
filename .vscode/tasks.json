{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "seedDb",
      "type": "pickString",
      "description": "Refresh (wipe and re-seed) the local database?",
      "options": [
        { "label": "No  — keep existing data", "value": "no" },
        { "label": "Yes — wipe and re-seed",   "value": "yes" }
      ],
      "default": "no"
    }
  ],
  "tasks": [
    // ── Backend ────────────────────────────────────────────────────────────────
    {
      "label": "Start Functions (Local)",
      "type": "shell",
      "command": "func",
      "args": ["start"],
      "options": {
        "cwd": "${workspaceFolder}/src/Hoops.Functions",
        "env": {
          "SEED_DB": "${input:seedDb}"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Azure Functions Core Tools.*",
          "endsPattern": ".*Worker process started and initialized.*"
        }
      }
    },
    {
      "label": "Start Functions (Local - Prod Data RO)",
      "type": "shell",
      "command": "func",
      "args": ["start"],
      "options": {
        "cwd": "${workspaceFolder}/src/Hoops.Functions",
        "env": {
          "USE_PROD_DATA": "true"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Azure Functions Core Tools.*",
          "endsPattern": ".*Worker process started and initialized.*"
        }
      }
    },
    // ── Frontend ───────────────────────────────────────────────────────────────
    {
      "label": "Start Frontend (Local)",
      "type": "shell",
      "command": "npm",
      "args": ["start"],
      "options": {
        "cwd": "${workspaceFolder}/hoops.ui/src"
      },
      "dependsOn": ["Start Functions (Local)"],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "Start Frontend (Dev Cloud API)",
      "type": "shell",
      "command": "npm",
      "args": ["start"],
      "options": {
        "cwd": "${workspaceFolder}/hoops.ui/src",
        "env": {
          "API_BASE_URL": "https://hoops-functions-dev-djeqhegwahbua7eq.eastus-01.azurewebsites.net"
        }
      },
      "problemMatcher": []
    },
    // ── Build / Test ───────────────────────────────────────────────────────────
    {
      "label": "Build Solution",
      "type": "shell",
      "command": "dotnet",
      "args": ["build", "Hoops.sln", "-c", "Debug", "/nologo"]
    },
    {
      "label": "Test Solution (fast)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "test",
        "Hoops.sln",
        "--filter",
        "TestCategory!=Slow",
        "--nologo"
      ],
      "group": "test"
    },
    {
      "label": "Build Functions (Debug)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "src/Hoops.Functions/Hoops.Functions.csproj",
        "-c",
        "Debug",
        "/nologo"
      ],
      "isBackground": false,
      "problemMatcher": ["$msCompile"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    // ── VS Code / Functions debugger tasks (used by launch.json) ──────────────
    {
      "label": "clean (functions)",
      "command": "dotnet",
      "args": [
        "clean",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "type": "process",
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/src\\Hoops.Functions"
      }
    },
    {
      "label": "build (functions)",
      "command": "dotnet",
      "args": [
        "build",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "type": "process",
      "dependsOn": "clean (functions)",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/src\\Hoops.Functions"
      }
    },
    {
      "label": "clean release (functions)",
      "command": "dotnet",
      "args": [
        "clean",
        "--configuration",
        "Release",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "type": "process",
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/src\\Hoops.Functions"
      }
    },
    {
      "label": "publish (functions)",
      "command": "dotnet",
      "args": [
        "publish",
        "--configuration",
        "Release",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "type": "process",
      "dependsOn": "clean release (functions)",
      "problemMatcher": "$msCompile",
      "options": {
        "cwd": "${workspaceFolder}/src\\Hoops.Functions"
      }
    },
    {
      "type": "func",
      "dependsOn": "build (functions)",
      "options": {
        "cwd": "${workspaceFolder}/src\\Hoops.Functions/bin/Debug/net9.0"
      },
      "command": "host start",
      "isBackground": true,
      "problemMatcher": "$func-dotnet-watch"
    },
    // ── Utilities ──────────────────────────────────────────────────────────────
    {
      "label": "Rename Angular Components",
      "type": "shell",
      "command": "node",
      "args": ["scripts/rename-components.mjs"]
    },
    {
      "label": "Lint Frontend",
      "type": "shell",
      "command": "npm",
      "args": ["run", "lint"],
      "isBackground": false,
      "problemMatcher": ["$eslint-stylish"],
      "group": "test"
    }
  ]
}
